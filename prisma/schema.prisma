generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

// ── Enums ──────────────────────────────────────────────────────

enum UserRole {
  ADMIN
  INVESTOR
  SUPER_ADMIN
}

enum UserStatus {
  PENDING_APPROVAL
  APPROVED
  REJECTED
}

enum NdaStatus {
  PENDING
  APPROVED
  REJECTED
}

enum InquiryStatus {
  NEW
  READ
  REPLIED
}

enum PipelineStage {
  LEAD
  NDA_PENDING
  UNDER_REVIEW
  COMMITTED
  CLOSED
}

enum QaCategory {
  GENERAL
  LEGAL
  FINANCIAL
  TECHNICAL
}

enum QaStatus {
  OPEN
  ANSWERED
  CLOSED
  REJECTED
}

enum DocLabel {
  NONE
  CONFIDENTIAL
  DRAFT
  FINAL
  REVIEWED
}

enum DocStatus {
  DRAFT
  PUBLISHED
}

enum ProjectLifecycle {
  PREPARATION
  LIVE
  LOCKED
  CLOSED
}

enum KycStatus {
  NOT_STARTED
  PENDING
  APPROVED
  REJECTED
}

enum ESignStatus {
  PENDING
  SIGNED
  DECLINED
  EXPIRED
}

enum NotifType {
  NDA_SUBMITTED
  NDA_APPROVED
  NDA_REJECTED
  ACCESS_GRANTED
  ACCESS_REVOKED
  QA_ANSWERED
  NEW_DOCUMENT
  NEW_MESSAGE
  KYC_APPROVED
  KYC_REJECTED
  ESIGN_REQUEST
  ESIGN_COMPLETED
  WORKFLOW_FIRED
}

enum WorkflowTrigger {
  NDA_SIGNED
  NDA_APPROVED
  INVESTOR_REGISTERED
  ACCESS_GRANTED
  DOC_OPENED_5X
  KYC_APPROVED
}

enum WorkflowAction {
  GRANT_ACCESS
  SEND_EMAIL
  SET_PIPELINE_STAGE
  CREATE_NOTE
  NOTIFY_ADMIN
}

enum CapTableEntryType {
  EQUITY
  DEBT
  CONVERTIBLE
  SAFE
  OTHER
}

// ── Tenant (multi-portail) ──────────────────────────────────────

model Tenant {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  domain      String?  @unique
  logoUrl     String?  @map("logo_url") @db.Text
  brandColor  String?  @map("brand_color")
  plan        String   @default("starter")
  stripeCustomerId String? @map("stripe_customer_id")
  stripeSubId String?  @map("stripe_sub_id")
  active      Boolean  @default(true)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  users    TenantUser[]
  projects Project[]
  plan     TenantPlan?

  @@map("tenants")
}

model TenantUser {
  id       String @id @default(cuid())
  tenantId String @map("tenant_id")
  userId   String @map("user_id")
  role     String @default("admin")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, userId])
  @@map("tenant_users")
}

// ── Users ──────────────────────────────────────────────────────

model User {
  id        String     @id @default(cuid())
  email     String     @unique
  password  String
  role      UserRole   @default(INVESTOR)
  status    UserStatus @default(PENDING_APPROVAL)
  createdAt DateTime   @default(now()) @map("created_at")
  updatedAt DateTime   @updatedAt @map("updated_at")

  profile             InvestorProfile?
  ndaRequests         NdaRequest[]
  accessGrants        AccessGrant[]
  documentActivities  DocumentActivity[]
  contactInquiries    ContactInquiry[]
  projectQuestions    ProjectQuestion[]
  uploadedDocuments   Document[]           @relation("UploadedBy")
  passwordResetTokens PasswordResetToken[]
  loginOtps           LoginOtp[]
  invitations         ProjectInvitation[]
  investorNotes       InvestorNote[]
  investorTags        InvestorTagAssign[]
  groupMembers        InvestorGroupMember[]
  termsAcceptances    TermsAcceptance[]
  notifications       Notification[]
  chatMessages        ChatMessage[]
  kycDocuments        KycDocument[]
  eSignRequests       ESignatureRequest[]  @relation("ESignRecipient")
  capTableEntries     CapTableEntry[]
  bulkEmailRecipients BulkEmailRecipient[]

  @@map("users")
}

model InvestorProfile {
  id            String        @id @default(cuid())
  userId        String        @unique @map("user_id")
  firstName     String        @map("first_name")
  lastName      String        @map("last_name")
  email         String
  phone         String
  companyName   String?       @map("company_name")
  country       String?
  city          String?
  jobTitle      String?       @map("job_title")
  investorType  String?       @map("investor_type")
  estTicket     String?       @map("est_ticket")
  notes         String?       @db.Text
  pipelineStage PipelineStage @default(LEAD) @map("pipeline_stage")
  kycStatus     KycStatus     @default(NOT_STARTED) @map("kyc_status")
  aiScore       Int           @default(0) @map("ai_score")
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("investor_profiles")
}

// ── Projects ───────────────────────────────────────────────────

model Project {
  id               String           @id @default(cuid())
  tenantId         String?          @map("tenant_id")
  name             String
  slug             String           @unique
  summary          String?          @db.Text
  description      String?          @db.LongText
  country          String?
  sector           String?
  status           String           @default("Open")
  lifecycle        ProjectLifecycle @default(PREPARATION)
  minTicket        Int?             @map("min_ticket")
  irrTargetBps     Int?             @map("irr_target_bps")
  investmentType   String?          @map("investment_type")
  targetRaise      BigInt?          @map("target_raise")
  raisedAmount     BigInt?          @map("raised_amount")
  currency         String           @default("USD")
  expectedDuration String?          @map("expected_duration")
  riskLevel        String?          @map("risk_level")
  highlights       Json?
  ndaText          String?          @map("nda_text") @db.LongText
  termsOfUse       String?          @map("terms_of_use") @db.LongText
  closingDate      DateTime?        @map("closing_date")
  isFeatured       Boolean          @default(false) @map("is_featured")
  sortOrder        Int              @default(0) @map("sort_order")
  teaserPublic     Boolean          @default(false) @map("teaser_public")
  seoIndexable     Boolean          @default(false) @map("seo_indexable")
  ndaRequired      Boolean          @default(true) @map("nda_required")
  kycRequired      Boolean          @default(false) @map("kyc_required")
  coverImage       String?          @map("cover_image") @db.Text
  logoImage        String?          @map("logo_image") @db.Text
  videoUrl         String?          @map("video_url")
  gallery          Json?
  brandColor       String?          @map("brand_color")
  brandLogo        String?          @map("brand_logo") @db.Text
  brandName        String?          @map("brand_name")
  publicMetrics    Json?            @map("public_metrics")
  notifyOnOpen     Boolean          @default(false) @map("notify_on_open")
  twoFaRequired    Boolean          @default(false) @map("two_fa_required")
  defaultAccessDays Int?            @map("default_access_days")
  workflowAutoApprove Boolean       @default(false) @map("workflow_auto_approve")
  createdAt        DateTime         @default(now()) @map("created_at")
  updatedAt        DateTime         @updatedAt @map("updated_at")

  tenant             Tenant?              @relation(fields: [tenantId], references: [id])
  ndaRequests        NdaRequest[]
  accessGrants       AccessGrant[]
  documents          Document[]
  documentFolders    DocumentFolder[]
  documentActivities DocumentActivity[]
  contactInquiries   ContactInquiry[]
  projectQuestions   ProjectQuestion[]
  invitations        ProjectInvitation[]
  updates            ProjectUpdate[]
  ddChecklist        DdChecklistItem[]
  investorGroups     InvestorGroup[]
  termsAcceptances   TermsAcceptance[]
  chatMessages       ChatMessage[]
  capTable           CapTableEntry[]
  workflowRules      WorkflowRule[]
  eSignRequests      ESignatureRequest[]

  @@map("projects")
}

// ── NDA ────────────────────────────────────────────────────────

model NdaRequest {
  id             String    @id @default(cuid())
  userId         String    @map("user_id")
  projectId      String    @map("project_id")
  status         NdaStatus @default(PENDING)
  signerFullName String?   @map("signer_full_name")
  signerIp       String?   @map("signer_ip")
  signatureType  String?   @map("signature_type")
  signatureData  String?   @map("signature_data") @db.LongText
  signedAt       DateTime? @map("signed_at")
  signedPdfPath  String?   @map("signed_pdf_path") @db.Text
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("nda_requests")
}

model AccessGrant {
  id            String        @id @default(cuid())
  userId        String        @map("user_id")
  projectId     String        @map("project_id")
  grantedAt     DateTime      @default(now()) @map("granted_at")
  expiresAt     DateTime?     @map("expires_at")
  revokedAt     DateTime?     @map("revoked_at")
  pipelineStage PipelineStage @default(UNDER_REVIEW) @map("pipeline_stage")

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([userId, projectId])
  @@map("access_grants")
}

model ProjectInvitation {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  projectId   String   @map("project_id")
  invitedById String?  @map("invited_by_id")
  createdAt   DateTime @default(now()) @map("created_at")

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([userId, projectId])
  @@map("project_invitations")
}

model TermsAcceptance {
  id         String   @id @default(cuid())
  userId     String   @map("user_id")
  projectId  String   @map("project_id")
  acceptedAt DateTime @default(now()) @map("accepted_at")
  ipAddress  String?  @map("ip_address")

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([userId, projectId])
  @@map("terms_acceptances")
}

// ── Documents ──────────────────────────────────────────────────

model DocumentFolder {
  id        String   @id @default(cuid())
  projectId String   @map("project_id")
  parentId  String?  @map("parent_id")
  name      String
  index     String?
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")

  project   Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  parent    DocumentFolder?  @relation("FolderTree", fields: [parentId], references: [id])
  children  DocumentFolder[] @relation("FolderTree")
  documents Document[]

  @@map("document_folders")
}

model Document {
  id            String    @id @default(cuid())
  projectId     String    @map("project_id")
  folderId      String?   @map("folder_id")
  name          String
  fileType      String    @map("file_type")
  filePath      String    @map("file_path") @db.Text
  sizeBytes     Int?      @map("size_bytes")
  version       Int       @default(1)
  supersededBy  String?   @map("superseded_by")
  uploadedById  String?   @map("uploaded_by_id")
  label         DocLabel  @default(NONE)
  status        DocStatus @default(PUBLISHED)
  internalNote  String?   @map("internal_note") @db.Text
  allowView     Boolean   @default(true) @map("allow_view")
  allowDownload Boolean   @default(true) @map("allow_download")
  allowPrint    Boolean   @default(false) @map("allow_print")
  sortOrder     Int       @default(0) @map("sort_order")
  publishedAt   DateTime? @map("published_at")
  aiSummary     String?   @map("ai_summary") @db.Text
  createdAt     DateTime  @default(now()) @map("created_at")

  project     Project              @relation(fields: [projectId], references: [id], onDelete: Cascade)
  folder      DocumentFolder?      @relation(fields: [folderId], references: [id])
  uploadedBy  User?                @relation("UploadedBy", fields: [uploadedById], references: [id])
  activities  DocumentActivity[]
  versions    DocumentVersion[]
  permissions DocumentPermission[]
  ddItems     DdChecklistItem[]
  heatmapData DocumentHeatmap[]
  eSignReqs   ESignatureRequest[]

  @@map("documents")
}

model DocumentPermission {
  id            String  @id @default(cuid())
  documentId    String  @map("document_id")
  userId        String  @map("user_id")
  allowView     Boolean @default(true) @map("allow_view")
  allowDownload Boolean @default(true) @map("allow_download")
  allowPrint    Boolean @default(false) @map("allow_print")

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@unique([documentId, userId])
  @@map("document_permissions")
}

model DocumentVersion {
  id         String   @id @default(cuid())
  documentId String   @map("document_id")
  version    Int
  filePath   String   @map("file_path") @db.Text
  sizeBytes  Int?     @map("size_bytes")
  note       String?
  uploadedAt DateTime @default(now()) @map("uploaded_at")
  uploadedBy String?  @map("uploaded_by")

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@map("document_versions")
}

model DocumentActivity {
  id         String   @id @default(cuid())
  documentId String   @map("document_id")
  userId     String   @map("user_id")
  projectId  String   @map("project_id")
  event      String
  durationMs Int?     @map("duration_ms")
  ipHash     String?  @map("ip_hash")
  country    String?
  city       String?
  userAgent  String?  @map("user_agent") @db.Text
  viewedAt   DateTime @default(now()) @map("viewed_at")

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  project  Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("document_activities")
}

model DocumentHeatmap {
  id         String   @id @default(cuid())
  documentId String   @map("document_id")
  userId     String   @map("user_id")
  pageNumber Int      @map("page_number")
  durationMs Int      @default(0) @map("duration_ms")
  viewCount  Int      @default(1) @map("view_count")
  updatedAt  DateTime @updatedAt @map("updated_at")

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@unique([documentId, userId, pageNumber])
  @@map("document_heatmaps")
}

// ── E-Signature ────────────────────────────────────────────────

model ESignatureRequest {
  id            String      @id @default(cuid())
  documentId    String      @map("document_id")
  projectId     String      @map("project_id")
  recipientId   String      @map("recipient_id")
  status        ESignStatus @default(PENDING)
  signatureData String?     @map("signature_data") @db.LongText
  signatureType String?     @map("signature_type")
  signerIp      String?     @map("signer_ip")
  signedAt      DateTime?   @map("signed_at")
  expiresAt     DateTime?   @map("expires_at")
  signedPdfPath String?     @map("signed_pdf_path") @db.Text
  message       String?     @db.Text
  createdAt     DateTime    @default(now()) @map("created_at")

  document  Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  recipient User     @relation("ESignRecipient", fields: [recipientId], references: [id], onDelete: Cascade)

  @@map("esign_requests")
}

// ── Chat ───────────────────────────────────────────────────────

model ChatMessage {
  id        String   @id @default(cuid())
  projectId String   @map("project_id")
  userId    String   @map("user_id")
  content   String   @db.Text
  isAdmin   Boolean  @default(false) @map("is_admin")
  readAt    DateTime? @map("read_at")
  fileUrl   String?  @map("file_url") @db.Text
  fileName  String?  @map("file_name")
  createdAt DateTime @default(now()) @map("created_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("chat_messages")
}

// ── Notifications ──────────────────────────────────────────────

model Notification {
  id        String    @id @default(cuid())
  userId    String    @map("user_id")
  type      NotifType
  title     String
  body      String    @db.Text
  link      String?
  readAt    DateTime? @map("read_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

// ── KYC ────────────────────────────────────────────────────────

model KycDocument {
  id          String    @id @default(cuid())
  userId      String    @map("user_id")
  docType     String    @map("doc_type")
  filePath    String    @map("file_path") @db.Text
  fileName    String    @map("file_name")
  status      KycStatus @default(PENDING)
  adminNote   String?   @map("admin_note") @db.Text
  reviewedAt  DateTime? @map("reviewed_at")
  reviewedBy  String?   @map("reviewed_by")
  createdAt   DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("kyc_documents")
}

// ── Cap Table ──────────────────────────────────────────────────

model CapTableEntry {
  id         String            @id @default(cuid())
  projectId  String            @map("project_id")
  userId     String?           @map("user_id")
  investorName String          @map("investor_name")
  amount     BigInt
  percentage Float?
  entryType  CapTableEntryType @default(EQUITY) @map("entry_type")
  note       String?           @db.Text
  createdAt  DateTime          @default(now()) @map("created_at")
  updatedAt  DateTime          @updatedAt @map("updated_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@map("cap_table_entries")
}

// ── Workflow Automation ────────────────────────────────────────

model WorkflowRule {
  id         String          @id @default(cuid())
  projectId  String          @map("project_id")
  name       String
  trigger    WorkflowTrigger
  conditions Json?
  action     WorkflowAction
  actionData Json?           @map("action_data")
  active     Boolean         @default(true)
  runCount   Int             @default(0) @map("run_count")
  lastRunAt  DateTime?       @map("last_run_at")
  createdAt  DateTime        @default(now()) @map("created_at")

  project Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  logs    WorkflowLog[]

  @@map("workflow_rules")
}

model WorkflowLog {
  id         String   @id @default(cuid())
  ruleId     String   @map("rule_id")
  userId     String?  @map("user_id")
  result     String
  details    String?  @db.Text
  executedAt DateTime @default(now()) @map("executed_at")

  rule WorkflowRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)

  @@map("workflow_logs")
}

// ── Bulk Email ─────────────────────────────────────────────────

model BulkEmailCampaign {
  id        String   @id @default(cuid())
  subject   String
  body      String   @db.LongText
  segment   String   @default("all")
  sentAt    DateTime? @map("sent_at")
  sentCount Int      @default(0) @map("sent_count")
  createdAt DateTime @default(now()) @map("created_at")

  recipients BulkEmailRecipient[]

  @@map("bulk_email_campaigns")
}

model BulkEmailRecipient {
  id         String   @id @default(cuid())
  campaignId String   @map("campaign_id")
  userId     String   @map("user_id")
  sentAt     DateTime? @map("sent_at")
  openedAt   DateTime? @map("opened_at")

  campaign BulkEmailCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  user     User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([campaignId, userId])
  @@map("bulk_email_recipients")
}

// ── Due Diligence Checklist ────────────────────────────────────

model DdChecklistItem {
  id          String   @id @default(cuid())
  projectId   String   @map("project_id")
  name        String
  description String?  @db.Text
  required    Boolean  @default(true)
  documentId  String?  @map("document_id")
  sortOrder   Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at")

  project  Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  document Document? @relation(fields: [documentId], references: [id], onDelete: SetNull)

  @@map("dd_checklist_items")
}

// ── Investor Groups ────────────────────────────────────────────

model InvestorGroup {
  id            String  @id @default(cuid())
  projectId     String  @map("project_id")
  name          String
  color         String  @default("#2563EB")
  allowView     Boolean @default(true) @map("allow_view")
  allowDownload Boolean @default(true) @map("allow_download")
  allowPrint    Boolean @default(false) @map("allow_print")

  createdAt DateTime @default(now()) @map("created_at")

  project Project               @relation(fields: [projectId], references: [id], onDelete: Cascade)
  members InvestorGroupMember[]

  @@map("investor_groups")
}

model InvestorGroupMember {
  id      String @id @default(cuid())
  userId  String @map("user_id")
  groupId String @map("group_id")

  user  User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  group InvestorGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([userId, groupId])
  @@map("investor_group_members")
}

// ── Project Updates ────────────────────────────────────────────

model ProjectUpdate {
  id        String   @id @default(cuid())
  projectId String   @map("project_id")
  title     String
  content   String   @db.LongText
  isPublic  Boolean  @default(true) @map("is_public")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("project_updates")
}

// ── CRM ────────────────────────────────────────────────────────

model InvestorNote {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  content   String   @db.Text
  createdAt DateTime @default(now()) @map("created_at")
  createdBy String?  @map("created_by")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("investor_notes")
}

model InvestorTag {
  id    String @id @default(cuid())
  name  String @unique
  color String @default("#2563EB")

  assignments InvestorTagAssign[]

  @@map("investor_tags")
}

model InvestorTagAssign {
  id     String @id @default(cuid())
  userId String @map("user_id")
  tagId  String @map("tag_id")

  user User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  tag  InvestorTag @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([userId, tagId])
  @@map("investor_tag_assigns")
}

// ── Communication ──────────────────────────────────────────────

model ContactInquiry {
  id         String        @id @default(cuid())
  userId     String        @map("user_id")
  projectId  String?       @map("project_id")
  ticketSize String?       @map("ticket_size")
  message    String?       @db.Text
  status     InquiryStatus @default(NEW)
  adminNote  String?       @map("admin_note") @db.Text
  createdAt  DateTime      @default(now()) @map("created_at")
  updatedAt  DateTime      @updatedAt @map("updated_at")

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  project Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@map("contact_inquiries")
}

model ProjectQuestion {
  id          String     @id @default(cuid())
  projectId   String     @map("project_id")
  userId      String     @map("user_id")
  parentId    String?    @map("parent_id")
  question    String     @db.Text
  answer      String?    @db.Text
  category    QaCategory @default(GENERAL)
  status      QaStatus   @default(OPEN)
  isShared    Boolean    @default(false) @map("is_shared")
  answeredAt  DateTime?  @map("answered_at")
  answeredBy  String?    @map("answered_by")
  createdAt   DateTime   @default(now()) @map("created_at")

  project     Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent      ProjectQuestion?  @relation("QaThread", fields: [parentId], references: [id])
  followUps   ProjectQuestion[] @relation("QaThread")
  attachments QaAttachment[]

  @@map("project_questions")
}

model QaAttachment {
  id         String   @id @default(cuid())
  questionId String   @map("question_id")
  filePath   String   @map("file_path") @db.Text
  fileName   String   @map("file_name")
  sizeBytes  Int?     @map("size_bytes")
  uploadedAt DateTime @default(now()) @map("uploaded_at")

  question ProjectQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@map("qa_attachments")
}

// ── Auth helpers ───────────────────────────────────────────────

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  used      Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("password_reset_tokens")
}

model LoginOtp {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  code      String   @db.Char(6)
  expiresAt DateTime @map("expires_at")
  used      Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("login_otps")
}

model SiteSetting {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("site_settings")
}

// ── Audit Log (append-only, never delete) ─────────────────────

model AuditEntry {
  id         String   @id @default(cuid())
  action     String
  userId     String?  @map("user_id")
  targetId   String?  @map("target_id")
  targetType String?  @map("target_type")
  details    String?  @db.Text
  ipHash     String?  @map("ip_hash")
  userAgent  String?  @map("user_agent") @db.Text
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@map("audit_entries")
}

// ═══════════════════════════════════════════════════════════════
// V5 — Multi-tenant SaaS + Marketplace + Investor Portfolio
// ═══════════════════════════════════════════════════════════════

// ── New Enums ──────────────────────────────────────────────────

enum TenantPlanName {
  STARTER
  PRO
  ENTERPRISE
}

enum TenantStatus {
  ACTIVE
  SUSPENDED
  CANCELLED
  TRIAL
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELLED
  TRIALING
  INCOMPLETE
}

enum InvestmentStatus {
  PENDING
  CONFIRMED
  CANCELLED
  REFUNDED
}

enum DistributionType {
  RENTAL
  DIVIDEND
  CAPITAL_RETURN
  INTEREST
  OTHER
}

enum DistributionStatus {
  SCHEDULED
  PAID
  FAILED
}

enum ListingStatus {
  DRAFT
  ACTIVE
  FUNDED
  CLOSED
  SUSPENDED
}

enum PermissionLevel {
  NONE
  FENCE_VIEW
  VIEW
  DOWNLOAD_ENCRYPTED
  PRINT
  DOWNLOAD_PDF
  DOWNLOAD_ORIGINAL
  UPLOAD
}

enum SecurityEventType {
  LOGIN
  LOGOUT
  DOC_VIEW
  DOC_DOWNLOAD
  SHARE_ATTEMPT
  IP_BLOCKED
  SESSION_EXPIRED
  DEVICE_MISMATCH
}

// ── Tenant (full v5) ───────────────────────────────────────────

model TenantPlan {
  id                  String             @id @default(cuid())
  tenantId            String             @unique @map("tenant_id")
  name                TenantPlanName     @default(STARTER)
  status              SubscriptionStatus @default(TRIALING)
  stripeCustomerId    String?            @map("stripe_customer_id")
  stripeSubscriptionId String?           @map("stripe_subscription_id")
  stripePriceId       String?            @map("stripe_price_id")
  currentPeriodStart  DateTime?          @map("current_period_start")
  currentPeriodEnd    DateTime?          @map("current_period_end")
  trialEndsAt         DateTime?          @map("trial_ends_at")
  cancelledAt         DateTime?          @map("cancelled_at")
  maxProjects         Int                @default(1)   @map("max_projects")
  maxInvestors        Int                @default(10)  @map("max_investors")
  maxStorageGb        Int                @default(5)   @map("max_storage_gb")
  createdAt           DateTime           @default(now()) @map("created_at")
  updatedAt           DateTime           @updatedAt @map("updated_at")

  @@map("tenant_plans")
}

model TenantBranding {
  id              String  @id @default(cuid())
  tenantId        String  @unique @map("tenant_id")
  logoUrl         String? @map("logo_url") @db.Text
  faviconUrl      String? @map("favicon_url") @db.Text
  primaryColor    String  @default("#1a7a4a") @map("primary_color")
  secondaryColor  String  @default("#1a2a4a") @map("secondary_color")
  accentColor     String  @default("#f59e0b") @map("accent_color")
  fontFamily      String  @default("Inter")   @map("font_family")
  portalName      String  @default("Investor Portal") @map("portal_name")
  tagline         String? @db.Text
  loginBg         String? @map("login_bg") @db.Text
  emailFromName   String  @default("Investor Portal") @map("email_from_name")
  supportEmail    String? @map("support_email")
  footerText      String? @map("footer_text")
  metaTitle       String? @map("meta_title")
  metaDescription String? @map("meta_description") @db.Text

  @@map("tenant_brandings")
}

model TenantDomain {
  id         String   @id @default(cuid())
  tenantId   String   @map("tenant_id")
  domain     String   @unique
  isPrimary  Boolean  @default(false) @map("is_primary")
  verified   Boolean  @default(false)
  sslActive  Boolean  @default(false) @map("ssl_active")
  createdAt  DateTime @default(now()) @map("created_at")

  @@map("tenant_domains")
}

model TenantUsage {
  id              String   @id @default(cuid())
  tenantId        String   @unique @map("tenant_id")
  projectCount    Int      @default(0) @map("project_count")
  investorCount   Int      @default(0) @map("investor_count")
  storageUsedMb   Float    @default(0) @map("storage_used_mb")
  lastCalculated  DateTime @default(now()) @map("last_calculated")

  @@map("tenant_usages")
}

// ── Marketplace ────────────────────────────────────────────────

model Listing {
  id              String        @id @default(cuid())
  projectId       String        @unique @map("project_id")
  tenantId        String        @map("tenant_id")
  status          ListingStatus @default(DRAFT)
  categoryId      String?       @map("category_id")
  title           String
  shortDesc       String        @map("short_desc") @db.Text
  targetReturn    Float?        @map("target_return")
  minTicketUsd    Int?          @map("min_ticket_usd")
  currency        String        @default("USD")
  region          String?
  isFeatured      Boolean       @default(false) @map("is_featured")
  featuredUntil   DateTime?     @map("featured_until")
  viewCount       Int           @default(0) @map("view_count")
  inquiryCount    Int           @default(0) @map("inquiry_count")
  publishedAt     DateTime?     @map("published_at")
  closingDate     DateTime?     @map("closing_date")
  seoSlug         String        @unique @map("seo_slug")
  seoTitle        String?       @map("seo_title")
  seoDescription  String?       @map("seo_description") @db.Text
  tags            Json?
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  category ListingCategory? @relation(fields: [categoryId], references: [id])

  @@index([status, isFeatured])
  @@index([tenantId])
  @@map("listings")
}

model ListingCategory {
  id          String    @id @default(cuid())
  name        String    @unique
  slug        String    @unique
  icon        String?
  description String?   @db.Text
  sortOrder   Int       @default(0) @map("sort_order")

  listings Listing[]

  @@map("listing_categories")
}

// ── Investments (off-platform, confirmed by admin) ─────────────

model Investment {
  id              String           @id @default(cuid())
  tenantId        String           @map("tenant_id")
  projectId       String           @map("project_id")
  investorId      String           @map("investor_id")
  amount          BigInt
  currency        String           @default("USD")
  exchangeRateUsd Float            @default(1) @map("exchange_rate_usd")
  amountUsd       Float            @map("amount_usd")
  status          InvestmentStatus @default(PENDING)
  confirmedAt     DateTime?        @map("confirmed_at")
  confirmedBy     String?          @map("confirmed_by")
  wireReference   String?          @map("wire_reference")
  notes           String?          @db.Text
  equity          Float?
  shareCount      Int?             @map("share_count")
  sharePrice      Float?           @map("share_price")
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")

  distributions Distribution[]

  @@index([investorId])
  @@index([projectId])
  @@map("investments")
}

model Distribution {
  id            String             @id @default(cuid())
  investmentId  String             @map("investment_id")
  tenantId      String             @map("tenant_id")
  investorId    String             @map("investor_id")
  amount        Float
  currency      String             @default("USD")
  type          DistributionType   @default(DIVIDEND)
  status        DistributionStatus @default(SCHEDULED)
  period        String?
  paidAt        DateTime?          @map("paid_at")
  notes         String?            @db.Text
  createdAt     DateTime           @default(now()) @map("created_at")

  investment Investment @relation(fields: [investmentId], references: [id], onDelete: Cascade)

  @@index([investorId])
  @@map("distributions")
}

// ── Security V5 ────────────────────────────────────────────────

model DocumentAccessRule {
  id              String          @id @default(cuid())
  documentId      String          @map("document_id")
  projectId       String          @map("project_id")
  permissionLevel PermissionLevel @default(VIEW) @map("permission_level")
  allowedIps      Json?           @map("allowed_ips")
  blockedCountries Json?          @map("blocked_countries")
  accessStartAt   DateTime?       @map("access_start_at")
  accessEndAt     DateTime?       @map("access_end_at")
  maxViews        Int?            @map("max_views")
  requireDevice   Boolean         @default(false) @map("require_device")
  watermarkText   String?         @map("watermark_text")
  enableFenceView Boolean         @default(false) @map("enable_fence_view")
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")

  @@unique([documentId])
  @@map("document_access_rules")
}

model DeviceFingerprint {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  fingerprint String
  userAgent   String?  @map("user_agent") @db.Text
  ipHash      String?  @map("ip_hash")
  country     String?
  city        String?
  trusted     Boolean  @default(false)
  lastSeen    DateTime @default(now()) @map("last_seen")
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@map("device_fingerprints")
}

model SecurityEvent {
  id          String            @id @default(cuid())
  userId      String?           @map("user_id")
  tenantId    String?           @map("tenant_id")
  type        SecurityEventType
  ipHash      String?           @map("ip_hash")
  country     String?
  userAgent   String?           @map("user_agent") @db.Text
  details     Json?
  severity    String            @default("info")
  createdAt   DateTime          @default(now()) @map("created_at")

  @@index([userId])
  @@index([tenantId])
  @@index([type])
  @@map("security_events")
}

model ProjectSecurityConfig {
  id               String   @id @default(cuid())
  projectId        String   @unique @map("project_id")
  ipWhitelist      Json?    @map("ip_whitelist")
  ipBlacklist      Json?    @map("ip_blacklist")
  countryWhitelist Json?    @map("country_whitelist")
  countryBlacklist Json?    @map("country_blacklist")
  sessionMaxHours  Int      @default(8) @map("session_max_hours")
  requireMfa       Boolean  @default(false) @map("require_mfa")
  deviceBinding    Boolean  @default(false) @map("device_binding")
  allowScreenshot  Boolean  @default(true) @map("allow_screenshot")
  watermarkAll     Boolean  @default(false) @map("watermark_all")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  @@map("project_security_configs")
}

// ── Investor Portfolio (cross-tenant) ─────────────────────────

model InvestorPortfolioSummary {
  id                String   @id @default(cuid())
  investorId        String   @unique @map("investor_id")
  totalInvestedUsd  Float    @default(0) @map("total_invested_usd")
  totalReceivedUsd  Float    @default(0) @map("total_received_usd")
  activeInvestments Int      @default(0) @map("active_investments")
  totalProjects     Int      @default(0) @map("total_projects")
  avgReturnRate     Float?   @map("avg_return_rate")
  lastUpdated       DateTime @default(now()) @map("last_updated")

  @@map("investor_portfolio_summaries")
}

model ReferralCode {
  id          String   @id @default(cuid())
  userId      String   @unique @map("user_id")
  code        String   @unique
  usageCount  Int      @default(0) @map("usage_count")
  rewardTotal Float    @default(0) @map("reward_total")
  createdAt   DateTime @default(now()) @map("created_at")

  referrals Referral[]

  @@map("referral_codes")
}

model Referral {
  id           String   @id @default(cuid())
  codeId       String   @map("code_id")
  referrerId   String   @map("referrer_id")
  referredId   String   @map("referred_id")
  rewardAmount Float    @default(0) @map("reward_amount")
  rewardPaid   Boolean  @default(false) @map("reward_paid")
  createdAt    DateTime @default(now()) @map("created_at")

  code ReferralCode @relation(fields: [codeId], references: [id])

  @@map("referrals")
}

// ── Super Admin ────────────────────────────────────────────────

model PlatformMetrics {
  id                String   @id @default(cuid())
  date              DateTime @unique @db.Date
  totalTenants      Int      @default(0) @map("total_tenants")
  activeTenants     Int      @default(0) @map("active_tenants")
  totalInvestors    Int      @default(0) @map("total_investors")
  totalProjects     Int      @default(0) @map("total_projects")
  totalInvestedUsd  Float    @default(0) @map("total_invested_usd")
  mrr               Float    @default(0)
  createdAt         DateTime @default(now()) @map("created_at")

  @@map("platform_metrics")
}

model StripeEvent {
  id          String   @id @default(cuid())
  stripeId    String   @unique @map("stripe_id")
  type        String
  data        Json
  processed   Boolean  @default(false)
  processedAt DateTime? @map("processed_at")
  error       String?  @db.Text
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("stripe_events")
}
